# Disable MultiViews to prevent Apache from guessing file extensions
# when a directory and a file share the same base name.
Options -MultiViews

RewriteEngine On

# Global redirect: www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Redirect explicit requests for /Admin to the subdomain
RewriteCond %{THE_REQUEST} \s/+Admin(?:/([^\s?]*))? [NC]
RewriteRule ^ https://admin.omniboardstudio.cz/%1 [R=301,L]

# Redirect admin.omniboardstudio.cz to Admin folder
RewriteCond %{HTTP_HOST} ^admin\.omniboardstudio\.cz [NC]
RewriteCond %{REQUEST_URI} !^/Admin/
RewriteRule ^(.*$) /Admin/$1 [L,QSA]

# Remove trailing slash from URLs (unless it is an actual, existing directory)
# This prevents the server from forcing a directory redirect if a folder is deleted or moved.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteRule ^ %1 [R=301,L]

# Strip .php extension from visible URLs (canonical redirect)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Deny direct HTTP access to the data directory
RewriteRule ^data(/.*)?$ - [F,L]

# Route /Admin/ and /Admin/index to Admin/index.php
RewriteRule ^Admin/?$ Admin/index.php [L]

# Route /Auth/* to Auth/*.php (OAuth callbacks)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^Auth/(.+)$ Auth/$1.php [L]

# Route /API/* to API/*.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^API/(.+)$ API/$1.php [L]

# Standard .php-extension routing for all other pages
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]